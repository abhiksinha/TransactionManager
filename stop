#!/usr/bin/env bash
set -euo pipefail

os="$(uname -s)"

is_windows() {
	case "$os" in
		MINGW*|MSYS*|CYGWIN*) return 0 ;;
		*) return 1 ;;
	esac
}

is_macos() {
	[[ "$os" == "Darwin" ]]
}

run_compose() {
	if docker info >/dev/null 2>&1; then
		docker compose down
		return
	fi
	sudo docker compose down
}

if is_windows || is_macos; then
	docker compose down
else
	run_compose
fi
